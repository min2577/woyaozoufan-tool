# ===========================================
# 我要揍饭 Server v2.0 - 环境变量配置
# ===========================================
# 复制此文件为 .env 并填写真实值

# ===========================================
# 🔑 火山引擎 API 配置
# ===========================================
VOLCENGINE_API_KEY=your_api_key_here
VOLCENGINE_MODEL_ID=doubao-seed-2-0-mini-260215

# ===========================================
# 🔑 阿里云 Qwen API 配置（备用，DashScope 兼容 OpenAI）
# ===========================================
QWEN_API_KEY=your_api_key_here
QWEN_MODEL_ID=qwen-plus
# QWEN_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions

# ===========================================
# 🖥️ 服务器配置
# ===========================================
PORT=3001
NODE_ENV=development
HOST=0.0.0.0

# ===========================================
# 🤖 AI 优化配置
# ===========================================
# AI 请求超时时间（毫秒）
AI_TIMEOUT=60000

# AI 重试配置
AI_MAX_RETRIES=3
AI_RETRY_DELAY=1000

# AI 缓存配置
AI_CACHE_ENABLED=true
AI_CACHE_TTL=3600000

# ===========================================
# 💾 数据库配置
# ===========================================
DATABASE_PATH=./data/recipes.db
DB_BUSY_TIMEOUT=5000

# ===========================================
# 📝 日志配置
# ===========================================
LOG_LEVEL=info
LOG_DIR=./logs
LOG_MAX_FILES=14
LOG_MAX_SIZE=10m
LOG_CONSOLE=true

# ===========================================
# 🌐 CORS 配置（可选）
# ===========================================
# 多个源用逗号分隔
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# ===========================================
# 🔔 通知配置（可选，待实现）
# ===========================================
# 飞书通知 Webhook
FEISHU_WEBHOOK=

# 邮件配置
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
